{
    "name": "navno-cms-archive-server",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "node build.mjs",
        "build-and-watch": "WATCH=true node build.mjs",
        "start": "node -r dotenv/config ./dist/server/server.cjs dotenv_config_path=../.env",
        "nodemon-start": "nodemon -r dotenv/config -w ./dist/server -w ../.env ./dist/server/server.cjs dotenv_config_path=../.env",
        "dev": "concurrently \"pnpm run build-and-watch\" \"pnpm run nodemon-start\""
    },
    "dependencies": {
        "navno-cms-archive-common": "workspace:*",
        "@opensearch-project/opensearch": "3.5.1",
        "archiver": "catalog:",
        "compression": "catalog:",
        "csp-header": "catalog:",
        "dotenv": "catalog:",
        "escape-html": "catalog:",
        "express": "catalog:",
        "http-terminator": "catalog:",
        "lru-cache": "catalog:",
        "mime-types": "3.0.2",
        "node-cache": "5.1.2",
        "puppeteer": "catalog:"
    },
    "devDependencies": {
        "@types/archiver": "catalog:",
        "@types/compression": "catalog:",
        "concurrently": "catalog:",
        "nodemon": "catalog:"
    },
    "nodemonConfig": {
        "delay": 500
    }
}
