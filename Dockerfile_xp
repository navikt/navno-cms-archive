FROM europe-north1-docker.pkg.dev/cgr-nav/pull-through/nav.no/node:25-dev

USER root
RUN apk add --no-cache chromium

WORKDIR /app/xp-archive/server

ENV NODE_ENV=production
ENV PUPPETEER_SKIP_DOWNLOAD=true
ENV PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
ENV XDG_CONFIG_HOME=/tmp/.chromium
ENV XDG_CACHE_HOME=/tmp/.chromium

COPY --chown=root:root --chmod=755 nonsymlink/xp-server/ /app/xp-archive/server/
COPY --chown=root:root --chmod=755 xp-archive/.env /app/xp-archive/

RUN mkdir -p /tmp/.chromium && chown 65532:65532 /tmp/.chromium

USER nonroot

EXPOSE 3499
CMD ["-r", "dotenv/config", "./dist/server/server.cjs", "dotenv_config_path=../.env"]
