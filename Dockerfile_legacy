FROM europe-north1-docker.pkg.dev/cgr-nav/pull-through/nav.no/node:24-dev

WORKDIR /app/legacy-archive/server

ENV NODE_ENV=production
ENV PUPPETEER_CACHE_DIR=/home/nonroot/.cache/puppeteer
ENV XDG_CONFIG_HOME=/tmp/.chromium
ENV XDG_CACHE_HOME=/tmp/.chromium

COPY --chown=root:root --chmod=755 nonsymlink/legacy-server/ /app/legacy-archive/server/

RUN mkdir -p /home/nonroot/.cache/puppeteer /tmp/.chromium \
    && node node_modules/puppeteer/install.mjs \
    && chown -R nonroot:nonroot /home/nonroot /tmp/.chromium

USER nonroot

EXPOSE 3399
CMD ["node", "-r", "dotenv/config", "./dist/server/server.cjs", "dotenv_config_path=../.env"]
