FROM node:24-bookworm-slim

RUN apt-get update \
    && apt-get --assume-yes --no-install-recommends install chromium curl \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app/legacy-archive/server

ENV NODE_ENV=production
ENV PUPPETEER_SKIP_DOWNLOAD=true
ENV PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
ENV XDG_CONFIG_HOME=/tmp/.chromium
ENV XDG_CACHE_HOME=/tmp/.chromium

RUN mkdir -p /app/legacy-archive/server /tmp/.chromium \
    && chown -R node:node /app /tmp/.chromium

COPY --chown=root:root --chmod=755 nonsymlink/legacy-server/ /app/legacy-archive/server/

USER node

EXPOSE 3399
CMD ["node", "-r", "dotenv/config", "./dist/server/server.cjs", "dotenv_config_path=../.env"]
